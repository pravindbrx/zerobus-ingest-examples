# Databricks workspace configuration
# Copy this file to .env and fill in your values before running.

# Your workspace numeric ID (find in the URL: adb-<WORKSPACE_ID>.N.azuredatabricks.net
# or from Settings > General > Workspace ID)
WORKSPACE_ID=1234567890123456

# Cloud region where your workspace lives (e.g. us-west-2, eastus, us-central1)
WORKSPACE_REGION=us-west-2

# Your workspace hostname (without https://)
# AWS example:   my-workspace.cloud.databricks.com
# Azure example: adb-1234567890123456.12.azuredatabricks.net
# GCP example:   1234567890123456.0.gcp.databricks.com
WORKSPACE_URL=my-workspace.cloud.databricks.com

# Service principal OAuth credentials
# Create a service principal at Settings > Identity and Access > Service Principals
# Then add a client secret under the service principal's OAuth tab
DATABRICKS_CLIENT_ID=abc123-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DATABRICKS_CLIENT_SECRET=your_client_secret_here

# Unity Catalog target — the table where logs will be written
CATALOG=my_catalog
SCHEMA=my_schema
TABLE=health_monitor_logs
