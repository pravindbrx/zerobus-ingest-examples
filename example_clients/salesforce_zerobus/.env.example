# Salesforce credentials
SALESFORCE_USERNAME=your-username@company.com
SALESFORCE_PASSWORD=your-password
SALESFORCE_TOKEN=your-security-token
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com
SALESFORCE_CHANGE_EVENT_CHANNEL=ChangeEvents
SALESFORCE_CLIENT_ID=your-salesforce-client-id
SALESFORCE_CLIENT_SECRET=your-salesforce-client-secret
SALESFORCE_IS_SANDBOX=false

# Databricks credentials (OAuth Service Principal)
DATABRICKS_WORKSPACE_URL=https://your-workspace.cloud.databricks.com
DATABRICKS_INGEST_ENDPOINT=workspace-id.ingest.cloud.databricks.com
DATABRICKS_SQL_ENDPOINT=/sql/1.0/warehouses/your-warehouse-id
DATABRICKS_ZEROBUS_TARGET_TABLE=your_catalog.your_database.your_table
DATABRICKS_CLIENT_ID=your-service-principal-client-id
DATABRICKS_CLIENT_SECRET=your-service-principal-client-secret