# Databricks / Zerobus
DATABRICKS_CLIENT_ID=<service-principal-client-id>
DATABRICKS_CLIENT_SECRET=<service-principal-client-secret>
DATABRICKS_WORKSPACE_URL=https://<workspace>.cloud.databricks.com
DATABRICKS_INGEST_ENDPOINT=<workspace-id>.zerobus.<region>.cloud.databricks.com
DATABRICKS_TABLE_NAME=<catalog>.<schema>.opcua_telemetry

# OPC UA
OPCUA_URL=opc.tcp://localhost:4840/freeopcua/server/
OPCUA_POLL_INTERVAL=5
OPCUA_NAMESPACE=2
TAGS_CONFIG_FILE=tags_config.yaml

# Batching
BATCH_SIZE=50
BATCH_TIMEOUT=2.0

# Backup (for Zerobus outages)
BACKUP_PATH=backup_opcua.jsonl

# OPC UA Security (leave blank for anonymous/no-encryption demo mode)
# For KEPServerEX production: Basic256Sha256,SignAndEncrypt
OPCUA_SECURITY_POLICY=
OPCUA_CERT_PATH=
OPCUA_KEY_PATH=
